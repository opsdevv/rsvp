# Copy to .env.local for local dev — Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Admin page only (admin.html). Do not use in the public RSVP bundle.
VITE_SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Vercel: Project → Settings → Environment Variables (Production + Preview).
# Vite inlines VITE_* at build time — redeploy after adding or changing them.
# Use the Vite/static build (npm run build → dist). PHP files are not run on Vercel.
